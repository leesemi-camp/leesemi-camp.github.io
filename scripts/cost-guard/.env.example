# Required
GCP_PROJECT_ID=semi-campaign-map
TARGET_PROJECT_ID=semi-campaign-map
BILLING_ACCOUNT_ID=000000-000000-000000
TELEGRAM_BOT_TOKEN=1234567890:your_bot_token
TELEGRAM_CHAT_ID=-1001234567890

# Deployment options
REGION=asia-northeast3
FUNCTION_NAME=billing-guard-telegram
FUNCTION_RUNTIME=nodejs22
SERVICE_ACCOUNT_ID=billing-guard-sa
BUDGET_TOPIC_ID=billing-budget-alerts
ENABLE_LEGACY_BUDGET_PUBLISHER_BINDING=false

# Function behavior
DISABLE_THRESHOLD=1.0
DISABLE_BILLING=true
SIMULATE_DISABLE=false

# Optional allowlists (comma-separated)
# BUDGET_ID_ALLOWLIST=de72f49d-779b-4945-a127-4d6ce8def0bb
# BUDGET_DISPLAY_NAME_ALLOWLIST=semi-campaign-monthly-budget

# Budget setup
BUDGET_DISPLAY_NAME=semi-campaign-monthly-budget
BUDGET_AMOUNT_UNITS=30000
CURRENCY_CODE=KRW

# Optional if auto-detect fails
# TARGET_PROJECT_NUMBER=123456789012
